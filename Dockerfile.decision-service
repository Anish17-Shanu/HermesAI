FROM maven:3.9.9-eclipse-temurin-8 AS builder
WORKDIR /workspace
COPY pom.xml pom.xml
COPY common-lib common-lib
COPY decision-service decision-service
RUN mvn -q -pl common-lib,decision-service -am package -DskipTests

FROM eclipse-temurin:8-jre
WORKDIR /app
COPY --from=builder /workspace/decision-service/target/decision-service-1.0.0.jar app.jar
ENTRYPOINT ["java","-jar","/app/app.jar"]
