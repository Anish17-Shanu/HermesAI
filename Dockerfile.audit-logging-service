FROM maven:3.9.9-eclipse-temurin-8 AS builder
WORKDIR /workspace
COPY pom.xml pom.xml
COPY common-lib common-lib
COPY audit-logging-service audit-logging-service
RUN mvn -q -pl common-lib,audit-logging-service -am package -DskipTests

FROM eclipse-temurin:8-jre
WORKDIR /app
COPY --from=builder /workspace/audit-logging-service/target/audit-logging-service-1.0.0.jar app.jar
ENTRYPOINT ["java","-jar","/app/app.jar"]
